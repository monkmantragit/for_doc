# Environment
NODE_ENV="development"  # or "production"

# Application URLs
NEXTAUTH_URL="http://localhost:3000"  # Base URL of your application
NEXT_PUBLIC_DOMAIN="http://localhost:3000"  # Public domain for client-side
ALLOWED_ORIGINS="http://localhost:3000"  # CORS allowed origins (comma-separated for multiple)

# Database Configuration
DATABASE_URL="postgresql://username:password@host:port/database"  # Your PostgreSQL connection string

# Authentication Secrets
# Generate these using: `openssl rand -base64 32`
JWT_SECRET="your_jwt_secret_here"  # Secret for JWT tokens
NEXTAUTH_SECRET="your_nextauth_secret_here"  # Secret for NextAuth.js

# Admin Account
ADMIN_EMAIL="your_admin_email@example.com"  # Admin login email
# Generate this using bcrypt (cost factor 10)
ADMIN_PASSWORD="$2b$10$YourHashedPasswordHere"  # Hashed admin password

# Email Configuration (SMTP) — used to notify the team of new fellowship applications.
# If these are not set, applications are still saved; only the notification email is skipped.
SMTP_HOST=""           # e.g. smtp.gmail.com / smtp.zoho.in / your host's SMTP server
SMTP_PORT="587"        # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=""           # SMTP username (often the full email address)
SMTP_PASSWORD=""       # SMTP password or app password
SMTP_FROM=""           # From address, e.g. "Sports Orthopedics <no-reply@yourdomain.com>"
# SMTP_SECURE="true"   # Optional: force TLS (auto-enabled for port 465)

# Email address that receives new fellowship application notifications.
# Falls back to ADMIN_EMAIL if unset.
FELLOWSHIP_NOTIFY_EMAIL=""

# Optional: force the fellowship application window regardless of date.
# "open" or "closed". Leave unset for normal date-based behaviour
# (open 1st–15th February and 1st–15th August, IST).
# FELLOWSHIP_WINDOW_OVERRIDE=""

# Optional: External Services
# GOOGLE_CALENDAR_ID=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET="" 

BOOKING_WEBHOOK_URL="https://primary-14xd-production.up.railway.app/webhook/ed002bd7-c14a-46dd-a141-a23b8f8281c7"